{
  "hooks": [
    {
      "events": ["PreToolUse"],
      "command": ["bash", ".claude/hooks/observe-pre-tool.sh"]
    },
    {
      "events": ["PostToolUse"],
      "command": ["bash", ".claude/hooks/observe-post-tool.sh"]
    },
    {
      "events": ["SubagentStart"],
      "command": ["bash", ".claude/hooks/observe-subagent-start.sh"]
    },
    {
      "events": ["SubagentStop"],
      "command": ["bash", ".claude/hooks/observe-subagent-stop.sh"]
    }
  ]
}
